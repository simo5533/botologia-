  "problemes_bdd": [
    { "id": "BDD-001", "severite": "moyenne", "description": "Champs assignedTo (Contact, Prospect), updatedBy (AppSettings), authorId (Activity) sans FK vers User", "fichier": "prisma/schema.prisma" },
    { "id": "BDD-002", "severite": "moyenne", "description": "Revenue.status, Notification.type, ScheduledTask.status en String libre — pas d'enum Prisma", "fichier": "prisma/schema.prisma" },
    { "id": "BDD-003", "severite": "moyenne", "description": "AppSettings.value en String @db.Text — pas Json structure (spec produit)", "fichier": "prisma/schema.prisma" },
    { "id": "BDD-004", "severite": "haute", "description": "DELETE /api/users/[id] effectue suppression physique malgre deletedAt sur User", "fichier": "app/api/users/[id]/route.ts" },
    { "id": "BDD-005", "severite": "moyenne", "description": "AuditLog : champs resource/resourceId ; userId parfois rempli avec la cible au lieu de l'acteur (routes users)", "fichier": "app/api/users/*.ts" },
    { "id": "BDD-006", "severite": "basse", "description": "Extension Prisma findMany/findFirst applique deletedAt: null a tous les modeles — verifier tout nouveau modele a bien deletedAt", "fichier": "lib/db/prisma.ts" },
    { "id": "BDD-007", "severite": "basse", "description": "BotConversation.userId sans relation Prisma vers User", "fichier": "prisma/schema.prisma" }
  ],
  "migrations_manquantes_recommandees": [
    { "id": "MIG-001", "description": "Script clean-invalid-fks puis FK optionnelles User pour Contact.assignedTo, Prospect.assignedTo, AppSettings.updatedBy, Activity.authorId, BotConversation.userId", "depend": "nettoyage donnees" },
    { "id": "MIG-002", "description": "Enums RevenueStatus, NotificationType, TaskStatus + migration donnees", "depend": "audit valeurs existantes" },
    { "id": "MIG-003", "description": "AppSettings : migration value String -> Json + valueType (si adopte)", "depend": "script migrate-settings-to-json" },
    { "id": "MIG-004", "description": "Index supplementaires Analytics/PageView/Revenue (si requetes lentes) — deja indexes de base presents", "depend": "mesure perf" }
  ],
