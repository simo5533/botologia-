{
  "name": "botoologia",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:port": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3000",
    "dev:alt": "cross-env PORT=3003 NODE_OPTIONS=--no-deprecation next dev -p 3003",
    "dev:docker": "docker compose --profile app up --build",
    "build": "prisma generate && next build",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:format": "prisma format",
    "db:push": "prisma db push",
    "db:push:docker": "docker compose --profile tools run --rm prisma-push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:studio:docker": "docker compose --profile tools run --rm prisma-studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:production": "cross-env PRISMA_SEED_PRODUCTION=1 npx tsx prisma/seed.ts",
    "db:seed:e2e": "npx tsx scripts/seed-e2e.ts",
    "db:seed:admins": "npx tsx prisma/seed-admins-2fa.ts",
    "test:e2e": "npx tsx scripts/seed-e2e.ts && npx playwright test",
    "test:e2e:ci": "npx playwright test --reporter=github",
    "audit": "npm audit --audit-level=high",
    "db:up": "docker compose up -d",
    "db:up:standalone": "docker compose -f docker-compose.standalone.yml up -d",
    "db:restart-standalone": "powershell -ExecutionPolicy Bypass -File scripts/db-restart-standalone-and-push.ps1",
    "db:up-safe": "powershell -ExecutionPolicy Bypass -File scripts/db-up-safe.ps1",
    "dev:full": "powershell -ExecutionPolicy Bypass -File scripts/demarrer-complet.ps1",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:check": "node scripts/check-db.js",
    "db:backup": "bash scripts/backup-db.sh",
    "db:backup:check": "node -e \"const fs=require('fs');const p='backups';try{const f=fs.readdirSync(p).filter(x=>x.endsWith('.sql.gz'));console.log(f.length?'Backups:',f.slice(-5).join(' '):'Aucun backup');}catch(e){console.log('Aucun backup');}\"",
    "db:introspect": "ts-node scripts/introspect-schema.ts",
    "db:introspect:tsx": "npx tsx scripts/introspect-schema.ts",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:full": "node scripts/audit.js",
    "check:all": "npm run typecheck && npm run test && npm run build",
    "check:deploy": "node scripts/verify-deps.js && npm run typecheck && npm run lint && npm run test:coverage && npm run build",
    "force": "npm run clean && npm ci && prisma generate && npm run typecheck && npm run test && npm run build",
    "prebuild:safe": "node -e \"const fs=require('fs');try{fs.rmSync('.next',{recursive:true,force:true});console.log('.next supprimé');}catch(e){if(e.code!=='ENOENT')throw e}\"",
    "build:clean": "npm run clean && npm run build",
    "build:fresh": "npm run prebuild:safe && npm run build",
    "fix:lint-deps": "npm ci",
    "audit:full:ts": "npx tsx scripts/audit-full.ts",
    "verify-deps": "node scripts/verify-deps.js",
    "verify-env": "node scripts/verify-deps.js && npm run build",
    "install:force": "powershell -ExecutionPolicy Bypass -File scripts/install-deps.ps1",
    "clean": "powershell -ExecutionPolicy Bypass -File scripts/clean-next.ps1",
    "copy-card-video": "powershell -ExecutionPolicy Bypass -File scripts/copy-card-video.ps1"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@monogrid/gainmap-js": "^3.0.6",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@prisma/client-runtime-utils": "7.4.0",
    "@radix-ui/react-dialog": "1.1.2",
    "@radix-ui/react-dropdown-menu": "2.1.2",
    "@radix-ui/react-label": "2.1.0",
    "@radix-ui/react-separator": "1.1.0",
    "@radix-ui/react-slot": "1.1.0",
    "@radix-ui/react-tabs": "1.1.1",
    "@react-spring/three": "^9.7.0",
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.0",
    "@react-three/postprocessing": "^2.16.0",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@types/nodemailer": "^7.0.11",
    "baseline-browser-mapping": "^2.10.24",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "framer-motion": "11.11.17",
    "gsap": "^3.14.2",
    "ioredis": "^5.4.2",
    "lenis": "^1.1.0",
    "lottie-react": "^2.4.0",
    "lucide-react": "0.460.0",
    "next": "14.2.35",
    "nodemailer": "^8.0.1",
    "pg": "^8.13.0",
    "postprocessing": "^6.36.0",
    "punycode": "^2.3.1",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.71.1",
    "react-intersection-observer": "^10.0.3",
    "react-parallax-tilt": "^1.7.0",
    "recharts": "^2.15.4",
    "speakeasy": "^2.0.0",
    "tailwind-merge": "2.5.4",
    "three": "^0.169.0",
    "three-stdlib": "^2.29.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "22.9.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@types/speakeasy": "^2.0.10",
    "@types/three": "^0.169.0",
    "@vitest/coverage-v8": "^2.1.6",
    "autoprefixer": "10.4.20",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "google-auth-library": "^10.6.2",
    "postcss": "8.4.49",
    "prisma": "^7.4.0",
    "tailwindcss": "3.4.15",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "5.6.3",
    "vitest": "^2.1.6"
  },
  "overrides": {
    "lodash": "4.17.23",
    "rimraf": "^5.0.10"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}
