# ═══════════════════════════════════════════════════════════════════════════
# BoTooLogIA — copier ce fichier vers .env (ne jamais commiter .env)
# ═══════════════════════════════════════════════════════════════════════════

# --- Application ---
APP_NAME="BoTooLogIA"
NODE_ENV="development"
# Déploiement Vercel + secrets : voir docs/DEPLOY_VERCEL.md
NEXT_TELEMETRY_DISABLED="1"
PORT="3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# --- Secrets (obligatoires en prod, min. 32 caractères) ---
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="REMPLACER_PAR_SECRET_32_CARACTERES_MINIMUM_ICI"
JWT_SECRET="REMPLACER_PAR_JWT_SECRET_32_CARACTERES_MINIMUM"
# Cookie / jeton pending 2FA (fallback sur JWT_SECRET si absent)
# PENDING_2FA_SECRET="..."

# --- PostgreSQL (Docker : voir docker-compose.yml, port hôte 5433) ---
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="botoologia"
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/botoologia?schema=public"

# Pool Prisma (optionnel)
# DB_POOL_MAX="10"

# --- Rate limiting distribué (optionnel, runtime Node — ioredis) ---
# Le middleware Next.js Edge utilise un store mémoire ; REDIS_URL sert surtout aux workers Node ou intégrations futures.
# REDIS_URL="redis://127.0.0.1:6379"

# --- Playwright / E2E (optionnel) ---
# PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"
# Après `npm run db:seed` : admin@botoologia.local / admin123 (sans 2FA)
# E2E_ADMIN_EMAIL="admin@botoologia.local"
# E2E_ADMIN_PASSWORD="admin123"
# Flux 2FA e2e : utilisateur avec 2FA + secret base32 identique à TEST_TOTP_SECRET
# E2E_2FA_EMAIL=""
# E2E_2FA_PASSWORD=""
# TEST_TOTP_SECRET=""

# --- Admin / auth ---
# Par défaut la protection est ACTIVE (dev et prod). Pour désactiver uniquement en local : false
# ADMIN_PROTECTION_ENABLED="false"
# Tests / CI uniquement : désactive validateEnvOrThrow au boot Next
# SKIP_ENV_VALIDATION="1"

# --- Agent IA (BOTO) — clés côté serveur uniquement, jamais dans le code ni Git ---
# Chaîne : 1) OpenAI (OPENAI_API_KEY) 2) Groq 3) Mistral 4) réponses locales si aucune clé
# Coller la clé OpenAI UNIQUEMENT dans .env (fichier local non versionné)
OPENAI_API_KEY=""
# Modèle OpenAI pour BOTO (défaut gpt-4o — ex. gpt-4o-mini pour limiter le coût)
# OPENAI_AGENT_MODEL="gpt-4o"
# GROQ_API_KEY=""
# MISTRAL_API_KEY=""

# --- SMTP (optionnel) ---
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="BoTooLogIA <noreply@example.com>"

# --- Liens publics (optionnel) ---
# NEXT_PUBLIC_INSTAGRAM_URL=""
# NEXT_PUBLIC_LINKEDIN_URL=""
# NEXT_PUBLIC_FACEBOOK_URL=""
# Email affiché / mailto RDV si pas d’URL de réservation
# NEXT_PUBLIC_CONTACT_EMAIL="contact@botoologia.com"
# Prise de rendez-vous (Cal.com, Calendly, HubSpot meetings, etc.) — prioritaire sur le mailto
# NEXT_PUBLIC_BOOKING_URL="https://cal.com/votre-lien/30min"
